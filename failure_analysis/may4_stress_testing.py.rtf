\cf0 import pandas as pd\
import yfinance as yf\
import matplotlib.pyplot as plt\
\
df_jpm = yf.download('JPM', '2018-01-01', '2023-12-31')\
df_xom = yf.download('XOM', '2018-01-01', '2023-12-31')\
\
close_jpm = df_jpm["Close"]\
close_xom = df_xom["Close"]\
\
full_range = pd.date_range(start='2018-01-10', end='2023-12-31', freq='B')\
\
close_combined = pd.concat([close_jpm, close_xom], axis=1)\
close_combined.columns = ['JPM', 'XOM']\
\
log_returns = np.log(close_combined/close_combined.shift(1)).dropna()\
\
mean_jpm = log_returns['JPM'].mean()\
mean_xom = log_returns['XOM'].mean()\
std_jpm = log_returns['JPM'].std()\
std_xom = log_returns['XOM'].std()\
\
def portfolio_vol_at_corr(corr, w1=0.5, w2=0.5, s1=std_jpm, s2=std_xom):\
  cov = corr * s1 * s2\
  portfolio_variance = w1**2 * s1**2 + w2**2 * s2**2 + 2 * w1 * w2 * cov\
  return np.sqrt(portfolio_variance) * np.sqrt(252)\
\
correlations = np.linspace(-1, 1, 200)\
port_vols_at_corr = [portfolio_vol_at_corr(c) for c in correlations]\
weighted_avg = 0.5 * std_jpm * np.sqrt(252) + 0.5 * std_xom * np.sqrt(252)\
div_benefits = [weighted_avg - v for v in port_vols_at_corr]\
\
key_corrs = [-1.0, -0.5, 0.0, 0.49, 0.5, 0.7, 0.8, 0.9, 0.95, 0.99, 1.0]\
for c in key_corrs:\
  vol = portfolio_vol_at_corr(c)\
  benefit = weighted_avg - vol\
  print(f"Correlation: \{c\}, Portfolio Vol: \{round(vol,4)\}, Diversification Benefit: \{round(benefit,4)\}")\
\
real_benefit = weighted_avg - portfolio_vol_at_corr(0.49)\
for c in correlations:\
  benefit = weighted_avg - portfolio_vol_at_corr(c)\
  if benefit <= real_benefit:\
    print("benefit drops by 50% at correlation: ", c)\
    break\
\
vol_multipliers = [1.0, 1.5, 2.0, 2.5, 3.0]\
for mult in vol_multipliers:\
  s1_stressed = std_jpm * mult\
  s2_stressed = std_xom * mult\
  portfolio_stressed = portfolio_vol_at_corr(0.49, s1=s1_stressed, s2=s2_stressed)\
  weighted_stressed = 0.5 * s1_stressed * np.sqrt(252) + 0.5 * s2_stressed * np.sqrt(252)\
  benefit_stressed = weighted_avg - portfolio_stressed\
  print(f"Vol multiplier: \{mult\}, Portfolio Vol: \{round(portfolio_stressed,4)\}, Benefit: \{round(benefit_stressed,4)\}")\
\
stress_corrs = [0.49, 0.7, 0.85, 0.95, 1.0]\
stress_vol_mult = 3.0\
print("Simultaneous stress test \'97 vol at 3x normal:")\
for c in stress_corrs:\
    s1_s = std_jpm * stress_vol_mult\
    s2_s = std_xom * stress_vol_mult\
    port_vol = portfolio_vol_at_corr(c, s1=s1_s, s2=s2_s)\
    weighted_s = 0.5 * s1_s * np.sqrt(252) + 0.5 * s2_s * np.sqrt(252)\
    benefit = weighted_s - port_vol\
    print(f"Corr: \{c\}, Portfolio Vol: \{round(port_vol,4)\}, Benefit: \{round(benefit,4)\}")\
}